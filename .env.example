# Copy to .env and fill in to enable the LIVE LLM judge + vision label reading.
# Leave empty to run fully offline in deterministic MOCK mode (demo never fails).
GROQ_API_KEY=

# Optional overrides
# LG_TEXT_MODEL=llama-3.3-70b-versatile
# LG_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# LG_MOCK=1            # force offline mode even if a key is present
